#!/usr/bin/env bash
set -eu

if [[ $(uname -s) == Darwin ]]; then
    PKG_ROOT=$(perl -e "use File::Basename; use Cwd qw(abs_path); print(dirname(dirname(abs_path('$0'))))")
else
    PKG_ROOT=$(dirname "$(dirname "$(realpath "$0")")")
fi

: "${JULIA_BIN:=julia}"

export JULIA_DEPOT_PATH="${JETLS_DEPOT:-$PKG_ROOT/store}"

exec "$JULIA_BIN" \
    --startup-file=no \
    --history-file=no \
    --threads=auto \
    --sysimage="$PKG_ROOT/lib/jetls.so" \
    --project="$PKG_ROOT/share/jetls" \
    -m JETLS "$@"
