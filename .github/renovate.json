{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "separateMinorPatch": false,
  "prConcurrentLimit": 1,
  "prCreation": "immediate",
  "automerge": false,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^UPSTREAM_VERSION$/"
      ],
      "matchStrings": [
        "^(?<currentValue>\\S+)\\s*$"
      ],
      "depNameTemplate": "aviatesk/JETLS.jl",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^(?<version>.*)$",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "github-releases"
      ],
      "matchPackageNames": [
        "aviatesk/JETLS.jl"
      ],
      "commitMessageTopic": "JETLS.jl",
      "commitMessageExtra": "to {{newValue}}"
    }
  ]
}
